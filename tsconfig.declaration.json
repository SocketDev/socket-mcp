{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false
  },
  "exclude": [
    "**/*.js",
    "**/*.test.ts",
    "node_modules",
    "coverage",
    ".github",
    ".claude",
    ".git-hooks",
    ".husky",
    "docs",
    "scripts/**/*.mts"
  ]
}
